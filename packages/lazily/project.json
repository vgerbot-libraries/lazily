{
    "name": "lazy",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/lazily/src",
    "projectType": "library",
    "tags": [],
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/packages/lazily/dist"],
            "options": {
                "commands": [
                    "nx run lazy:build:rollup",
                    "rm -f packages/lazily/dist/index.cjs.d.ts packages/lazily/dist/index.esm.d.ts",
                    "nx run lazy:build:dts",
                    "rm -rf packages/lazily/dist/src"
                ],
                "parallel": false
            }
        },
        "build:dts": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/packages/lazily/dist/index.d.ts"],
            "options": {
                "command": "rollup -c packages/lazily/rollup.config.dts.ts --configPlugin 'typescript={tsconfig: \"packages/lazily/tsconfig.dts.json\"}'"
            }
        },
        "build:rollup": {
            "executor": "@nx/rollup:rollup",
            "outputs": ["{workspaceRoot}/packages/lazily/dist"],
            "options": {
                "outputPath": "packages/lazily/dist",
                "main": "packages/lazily/src/index.ts",
                "tsConfig": "packages/lazily/tsconfig.lib.json",
                "project": "packages/lazily/package.json",
                "entryFile": "packages/lazily/src/index.ts",
                "format": ["esm"],
                "external": [],
                "rollupConfig": "packages/lazily/rollup.config.ts",
                "skipTypeCheck": true
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
            "options": {
                "jestConfig": "packages/lazily/jest.config.ts",
                "passWithNoTests": true,
                "codeCoverage": true
            },
            "configurations": {
                "ci": {
                    "ci": true,
                    "codeCoverage": true
                }
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "biome check packages/lazily"
            }
        }
    }
}
