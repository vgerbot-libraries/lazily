        "url": "https://github.com/vgerbot-libraries/lazily/issues"
    },
    "files": ["dist"],
    "keywords": [
        "lazy",
        "lazily",
        "laziness",
        "defer",
        "deferred",
        "evaluate",
        "evaluation",
        "compute",
