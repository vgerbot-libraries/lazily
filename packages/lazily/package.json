{
    "name": "@vgerbot/lazily",
    "version": "0.1.1",
    "description": "A tiny TypeScript utility for lazy initialization",
    "type": "module",
    "main": "./dist/index.esm.js",
    "module": "./dist/index.esm.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "tag": "latest",
        "access": "public"
